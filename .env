# This file is loaded by `just`. All variables are used only within the
# `justfile`, i.e., they are not exported to the environment of the commands
# that are executed by `just`. However, all variables beginning with `CMAKE_`
# or `TNL_` are passed to the CMake configure command using the -D option.
#
# See https://github.com/casey/just for general information about `just`.
# See https://cmake.org/cmake/help/latest/manual/cmake-variables.7.html for
# more information about CMake variables.

# Path to the build directory (relative to the project root)
BUILD_DIR=build

# Specifies the CMake default generator to use when no generator is supplied
# on the command line with -G
CMAKE_GENERATOR=Ninja

# Specifies a default value for the CMAKE_BUILD_TYPE variable when there is no
# explicit configuration given on the first run while creating a new build tree.
CMAKE_BUILD_TYPE=RelWithDebInfo

# Install directory used by install().
# The installation prefix is also added to CMAKE_SYSTEM_PREFIX_PATH so that
# find_package(), find_program(), find_library(), find_path(), and find_file()
# will search the prefix for other software. This behavior can be disabled by
# setting the CMAKE_FIND_NO_INSTALL_PREFIX to TRUE before the first project()
# invocation.
CMAKE_INSTALL_PREFIX="$HOME/.local"

# Build with CUDA support
TNL_USE_CUDA=ON

# Build with HIP support
TNL_USE_HIP=ON

# Build with OpenMP support
TNL_USE_OPENMP=ON

# Build with MPI support
TNL_USE_MPI=ON

# Build with GMP support
TNL_USE_GMP=OFF

# Use GTest installed in the local system and do not download the latest version
TNL_USE_SYSTEM_GTEST=OFF

# Add additional compiler flags like -Werror that are enforced in CI builds
TNL_USE_CI_FLAGS=OFF

# Add -march=native and -mtune=native to the list of compiler flags for the Release configuration
TNL_USE_MARCH_NATIVE_FLAG=OFF

# Enable code coverage reports from unit tests
TNL_BUILD_COVERAGE=OFF

# Offline build (i.e. without downloading libraries such as GTest)
TNL_OFFLINE_BUILD=OFF

# Instruct Doxygen to use Clang-assisted parsing
TNL_DOXYGEN_USE_CLANG=OFF
